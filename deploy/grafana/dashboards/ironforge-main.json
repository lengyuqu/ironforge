{
  "title": "IronForge - Production Overview",
  "uid": "ironforge-main",
  "tags": ["ironforge", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, route)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "📊 Request Rate (QPS)",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        { "label": "req/s", "format": "short" },
        { "format": "short" }
      ],
      "legend": { "showLegend": true, "displayMode": "table", "placement": "right" }
    },
    {
      "id": 2,
      "title": "⏱️ P95 Request Latency",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[$route])))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket[$route])))",
          "legendFormat": "p99 {{route}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "label": "seconds", "format": "s" },
        { "format": "short" }
      ]
    },
    {
      "id": 3,
      "title": "❌ Error Rate (5xx)",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (route)",
          "legendFormat": "5xx {{route}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[5m])) by (route)",
          "legendFormat": "4xx {{route}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        { "label": "errors/s", "format": "short" },
        { "format": "short" }
      ]
    },
    {
      "id": 4,
      "title": "🚀 In-Flight Requests",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "http_requests_in_flight",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 5,
      "title": "💾 DB Query Rate",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(db_queries_total[1m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "🐢 P95 DB Latency",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        { "label": "seconds", "format": "s" },
        { "format": "short" }
      ]
    },
    {
      "id": 7,
      "title": "📦 Git Operations",
      "type": "graph",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(git_operations_total[5m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "🔄 CI Pipeline Status",
      "type": "piechart",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(ci_pipelines_total) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "⚙️ Running CI Jobs",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "ci_jobs_running",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "💚 Health Status",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "up{job=\"ironforge\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "🧠 Memory Usage",
      "type": "gauge",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "💽 Disk Usage",
      "type": "gauge",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "🖥️ CPU Usage",
      "type": "gauge",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "targets": [
        {
          "expr": "1 - rate(node_cpu_seconds_total{mode=\"idle\"}[5m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    }
  ]
}
